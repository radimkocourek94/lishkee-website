            <ul class="text-text/80 space-y-2">
              <li><a class="toc-link block" href="#band-bio">Band bio</a></li>
              <li><a class="toc-link block" href="#genre-sound">Genre &amp; sound</a></li>
              <li><a class="toc-link block" href="#career-highlights">Career highlights</a></li>
              <li><a class="toc-link block" href="#discography">Discography</a></li>
              <li><a class="toc-link block" href="#collaborations">Collaborations &amp; features</a></li>
              <li><a class="toc-link block" href="#press-media">Press &amp; media</a></li>
              <li><a class="toc-link block" href="#band-members">Band members</a></li>
              <li><a class="toc-link block" href="#creative-approach">Creative approach</a></li>
              <li><a class="toc-link block" href="#location-scene">Location &amp; scene</a></li>
              <li><a class="toc-link block" href="#photos">Photos</a></li>
            </ul>
          </nav>
        </div>

        <script type="module">
          // Highlight current section in TOC using IntersectionObserver
          const links = Array.from(document.querySelectorAll('.toc-link'));
          const sections = links.map(l => document.querySelector(l.getAttribute('href'))).filter(Boolean);

          const obs = new IntersectionObserver((entries) => {
            entries.forEach(e => {
              const id = '#' + e.target.id;
              const link = document.querySelector(`.toc-link[href="${id}"]`);
              if (link) link.classList.toggle('active', e.isIntersecting);
            });
          }, { root: null, rootMargin: '0px 0px -60% 0px', threshold: 0 });

          sections.forEach(s => obs.observe(s));
          // Ensure TOC clicks reliably scroll to the section (handles browsers / offsets)
          document.querySelectorAll('.toc-link').forEach(a => {
            a.addEventListener('click', (ev) => {
              const href = a.getAttribute('href');
              if (!href || !href.startsWith('#')) return;
              ev.preventDefault();
              const target = document.querySelector(href);
              if (!target) return;
              const offset = window.innerWidth >= 1024 ? 80 : 56; // px (matches scroll-margin-top approx)
              const top = target.getBoundingClientRect().top + window.scrollY - offset;
              window.scrollTo({ top, behavior: 'smooth' });
              history.replaceState(null, '', href);
            });
          });
        </script>
      </aside>
    </div>

