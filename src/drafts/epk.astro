---
import BaseLayout from "../layouts/BaseLayout.astro"

const zipPath = "/docs/lishkee-EPK-v1.0.zip"

// small selection of images that already exist in public/images for quick previews
const images = [
  "/images/Lishkee3.jpg",
  "/images/Lishkee_Jakub_Joch.JPEG",
  "/images/Lishkee2.JPEG",
  "/images/Lishkee1.JPEG",
  "/images/Lishkee1_Tomáš_Škoda.jpg",
  "/images/Lishkee2_Tomáš_Škoda.jpg",
  "/images/Lishkee3_Tomáš_Škoda..jpg",
  "/images/Lishkee4_Tomáš_Škoda..jpg",
]
---

<BaseLayout title="Press Kit — Lishkee">
  <style>
    html { scroll-behavior: smooth; }
    /* TOC link styles */
    .toc-link { color: inherit; opacity: .9; }
    /* change active color to a brighter accent */
    .toc-link.active { font-weight: 600; color: #FF7BA9; }
    /* small visual focus for keyboard users */
    .toc-link:focus { outline: 2px solid rgba(255,255,255,0.12); outline-offset: 2px; }
    /* Ensure anchor targets (sections) are offset so headings remain visible
       when scrolled to via in-page links or the TOC. Adjusts for sticky UI.
    */
    section[id] { scroll-margin-top: 3.5rem; }
    @media (min-width: 1024px) {
      section[id] { scroll-margin-top: 5rem; }
    }
  </style>
  <div class="max-w-6xl mx-auto px-4 py-16">
    <!-- Header / CTA -->
    <div class="flex flex-col lg:flex-row items-start lg:items-center gap-6 mb-10">
      <div class="flex-1">
        <span class="accent-line mb-4 block"></span>
        <h1 class="text-4xl sm:text-5xl font-bold text-accent mb-2 normal-case font-body">Lishkee</h1>
        <h2 class="text-lg text-text/70">Electronic Press Kit</h2>
      </div>

      <div class="w-full lg:w-auto flex gap-3">
        <a href={zipPath} download class="btn-gradient inline-block px-5 py-3">Download full EPK (ZIP)</a>
        <a href="/music" class="px-4 py-3 rounded-md bg-white/5">Listen</a>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main content -->
        <main class="lg:col-span-2 space-y-6">
        <section id="band-bio" class="glass-card p-6 space-y-4">
          <h2 class="text-2xl font-semibold text-accent">BAND BIO</h2>
          <div class="prose prose-invert max-w-none text-text/90 prose-p:mb-6 leading-relaxed space-y-6">
            <p><strong>Lishkee</strong> is an indie alt-pop duo from Brno, Czech Republic, consisting of <strong>Viktória Šmídová</strong> and <strong>Radim Kocourek</strong> (both equally contributing to production, instrumentation, and songwriting). Operating with a DIY ethos from their small bedroom studio, the pair creates all their music independently, blending elements of electronica, pop, downtempo, and jazz into a distinctive sonic palette.</p>

            <p>The project emerged from their earlier incarnation as <strong>Stereofox</strong>, evolving into <strong>Lishkee</strong> with a refined artistic vision.</p>

            <p>Their sound is characterized by electronic beats interwoven with guitar textures and jazz-inflected vocals, creating an introspective atmosphere that draws listeners into layered instrumental landscapes. The music carries a cozy, nostalgic quality, with lyrics exploring personal themes like anxiety, self-reflection, and contemplation.</p>

            <p>Musically, Lishkee navigates the spaces between indie psychedelia and dream pop, crafting distinctive and original melodies that set them apart in the Czech alternative scene.</p>

            <p>Their use of delicate vocals with jazzy nuances, electronic rhythms, and layered instrumental textures creates a contemplative sonic environment that rewards deep listening. The duo's approach combines experimental sound design with clear melodic sensibility, maintaining a balance between spontaneity and careful composition.</p>

            <p>Their live shows feature the duo's introspective sound translated into an immersive performance experience, with layered electronics, live instrumentation, and their signature dreamy vocal delivery. The theatrical nature of their music makes them particularly suited to atmospheric and unconventional spaces.</p>
            
            <p class="italic">"Endless observers ✨ Music makers"</p>
            <p class="mt-2">— Lishkee</p>

          </div>
        </section>

        <section id="genre-sound" class="glass-card p-6 space-y-4">
          <h2 class="text-2xl font-semibold text-accent">GENRE &amp; SOUND</h2>
          <div class="prose prose-invert max-w-none text-text/90 prose-p:mb-6 leading-relaxed space-y-6">
            <p><strong>Primary Genres:</strong> Indie Alt-Pop, Dream Pop, Downtempo Pop, Experimental Pop</p>

            <p><strong>Musical Elements:</strong> Electronica, Jazz, Psychedelic Pop, Trip-Hop, Singer-Songwriter, Lo-Fi, Indietronica</p>

            <h4>Sound Characteristics:</h4>
            <ul>
              <li>Electronic beats layered with organic guitar work</li>
              <li>Jazz-influenced vocal delivery with soft, expressive performance</li>
              <li>Atmospheric and introspective production</li>
              <li>Melancholic yet captivating melodies</li>
              <li>DIY bedroom production aesthetic</li>
              <li>Hypnotic rhythms and dreamy textures</li>
              <li>Cozy, nostalgic feel</li>
              <li>Modular synth experimentation and spontaneous composition</li>
              <li>Lyrics exploring anxiety, self-reflection, and contemplation</li>
            </ul>

            <p><strong>Genre &amp; Sound Tags:</strong> Alternative, Alt Pop, Dream Pop, Dark Electronica, Experimental Pop, Indie Pop, Psychedelic Pop, Trip-Hop</p>

          </div>
        </section>

        <section id="career-highlights" class="glass-card p-6 space-y-4">
          <h2 class="text-2xl font-semibold text-accent">CAREER HIGHLIGHTS</h2>
          <div class="prose prose-invert max-w-none text-text/90 prose-p:mb-6 leading-relaxed space-y-6">
            <p><strong>2017</strong> - Released demo album <a href="https://lishkee.bandcamp.com/album/layers-2?t=2" target="_blank" rel="noopener noreferrer" aria-label="Layers" class="text-accent hover:text-accent-hover underline underline-offset-2 transition-colors">𝓛𝓪𝔂𝓮𝓻𝓼</a> (as Stereofox), which received a nomination for <strong>Debut of the Year at the Slovak Radio_Head Awards</strong></p>

            <p><strong>2018</strong> - Reached the finals of <strong>Radio Wave's Startér competition</strong> with the single "<a href="https://lishkee.bandcamp.com/track/distortions" target="_blank" rel="noopener noreferrer" aria-label="Distortions" class="text-accent hover:text-accent-hover underline underline-offset-2 transition-colors">𝓓𝓲𝓼𝓽𝓸𝓻𝓽𝓲𝓸𝓷𝓼</a>," earning them a performance slot at Slovakia's prestigious <strong>Pohoda Festival</strong></p>

            <p><strong>2021-2024</strong> - Released a critically acclaimed series of singles including "Game of Darts," "Flood," "Not Much Left to Be Worried About," "Nightstand," "Winter Voyage," "Another Sunday," "Breaking the Illusion," and "In Case of Emergency"</p>

            <p><strong>2024</strong> - Collaborated with Luca Minelli on "Endlessly," expanding their creative network</p>

            <p><strong>2024-2025</strong> - Released debut album <strong>"<a href="https://lishkee.bandcamp.com/album/collections-of-pink-blue-all-the-other-colors-too" target="_blank" rel="noopener noreferrer" aria-label="Collections of Pink, Blue, and All the Other Colors, Too" class="text-accent hover:text-accent-hover underline underline-offset-2 transition-colors">𝓒𝓸𝓵𝓵𝓮𝓬𝓽𝓲𝓸𝓷𝓼 𝓸𝓯 𝓟𝓲𝓷𝓴, 𝓑𝓵𝓾𝓮, 𝓪𝓷𝓭 𝓐𝓵𝓵 𝓽𝓱𝓮 𝓞𝓽𝓱𝓮𝓻 𝓒𝓸𝓵𝓸𝓻𝓼, 𝓣𝓸𝓸</a>"</strong> (April 2, 2025), an eclectic 12-track collection spanning their musical evolution, described as a mix of dream pop and dark electronica</p>

            <p><strong>2024-2025</strong> - Provided original music for <strong><a href="https://kaznice.art/program/divadelni-svet-brno-labyrint/" target="_blank" rel="noopener noreferrer">Labyrint</a></strong>, a site-specific theater performance at the historic Káznice (former prison) in Brno, as part of a collaborative project with Divadelní smečka, Brno dancers and performers, and filmmaker Petr Kačírka</p>

            <p><strong>2025</strong> - Released "Silver (Modular Version)" featuring Luca Minelli, recorded with modular synthesizers in a single take, showcasing their experimental approach</p>

            <p><strong>November 2025</strong> - Viktória Šmídová provided vocals for "Faraway Places" on <strong>Concrete Noir's debut album "Romance Ruins"</strong> (Frequens Records), an Italian darkwave/modular synth project by Piero Fragola. This marks Lishkee's first international collaboration on a major label release, expanding their reach into the European darkwave and coldwave scene.</p>

            <p><strong>Ongoing</strong> - Currently working on their second full-length album, building on the foundation established by their debut while continuing to explore new sonic territories</p>
          </div>
        </section>

        <section id="discography" class="glass-card p-6 space-y-4">
          <h2 class="text-2xl font-semibold text-accent">DISCOGRAPHY</h2>
          <div class="prose prose-invert max-w-none text-text/90 prose-p:mb-6 leading-relaxed space-y-6">
            <h3>Full-Length Albums</h3>

            <p><strong>"<a href="https://lishkee.bandcamp.com/album/collections-of-pink-blue-all-the-other-colors-too" target="_blank" rel="noopener noreferrer" aria-label="Collections of Pink, Blue, and All the Other Colors, Too" class="text-accent hover:text-accent-hover underline underline-offset-2 transition-colors">𝓒𝓸𝓵𝓵𝓮𝓬𝓽𝓲𝓸𝓷𝓼 𝓸𝓯 𝓟𝓲𝓷𝓴, 𝓑𝓵𝓾𝓮, 𝓪𝓷𝓭 𝓐𝓵𝓵 𝓽𝓱𝓮 𝓞𝓽𝓱𝓮𝓻 𝓒𝓸𝓵𝓸𝓻𝓼, 𝓣𝓸𝓸</a>"</strong> (April 2, 2025)</p>

            <p>Lishkee's debut album is an eclectic 12-track collection showcasing the duo's musical evolution over recent years. Described as "a mix of dream pop and dark electronica," the album brings together reimagined versions of fan-favorite singles alongside previously unreleased material.</p>

            <p>All tracks were recorded, produced, mixed, and mastered by Lishkee in their bedroom studio (except "In Case of Emergency," which was mixed and mastered by Jan Sobko). The album demonstrates their DIY ethos and ability to create polished, atmospheric productions independently.</p>

