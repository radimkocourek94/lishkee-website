---
import BaseLayout from "../../layouts/BaseLayout.astro"
import HeroSlider from "../../components/HeroSlider.astro"
import { band } from "../../data/band"
import { socialLabels, socialIcons } from "../../data/socials"
import { useTranslations } from "../../i18n"

const locale = "cs" as const
const t = useTranslations(locale)
---

<BaseLayout
  title={t("meta.home.title")}
  description={t("meta.home.description")}
  lang={locale}
>
  {/* 1. Hero Slideshow */}
  <HeroSlider lang={locale} />

  {/* Latest single card */}
  <section class="relative py-24 px-4 sm:px-6 lg:px-8 overflow-hidden">
    <div class="relative z-10 max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <span class="accent-line mb-4 block mx-auto" />
        <h2 class="text-3xl sm:text-5xl font-semibold text-accent mb-3">{t("home.latestSingle")}</h2>
      </div>

      <div class="glass-card p-6 sm:p-8 mx-auto w-full max-w-[420px]">
        <div class="flex flex-col items-center">
          <div class="w-full">
            <div class="embed-responsive embed-responsive--large-track">
              <div class="embed-inner">
                <iframe
                  loading="lazy"
                  src="https://bandcamp.com/EmbeddedPlayer/track=389067325/size=large/bgcol=333333/linkcol=ffffff/tracklist=false/transparent=true/"
                  title={t("home.iframeTitle")}
                ><a href="https://lishkee.bandcamp.com/track/nightmares">{t("home.iframeFallback")}</a></iframe>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider max-w-xs mx-auto" />

  {/* Follow Us */}
  <section class="relative py-24 px-4 sm:px-6 lg:px-8 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-accent/5 rounded-full blur-3xl" />
    </div>

    <div class="relative z-10 max-w-2xl mx-auto text-center">
      <span class="accent-line mb-6 block mx-auto" />
      <h2 class="text-3xl sm:text-5xl font-semibold text-accent mb-4">{t("home.stayInTheLoop")}</h2>
      <p class="text-text/70 mb-8 text-base sm:text-lg">{t("home.stayInTheLoopDesc")}</p>

      <div class="link-card-grid grid grid-cols-2 gap-3 sm:flex sm:flex-wrap sm:justify-center">
        {Object.entries(band.socials).map(([key, url]) =>
          url ? (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center justify-center gap-2.5 px-6 py-3 border border-white/10 rounded-xl text-sm font-medium text-text/80 hover:text-accent hover:border-accent/40 hover:bg-accent/5 transition-colors duration-200"
            >
              <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                <path d={socialIcons[key] || ""} />
              </svg>
              {socialLabels[key] || key}
            </a>
          ) : null
        )}
      </div>
    </div>
  </section>
</BaseLayout>
