---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { band } from "../../data/band"
import { socialLabels, socialIcons } from "../../data/socials"
import { useTranslations, localePath } from "../../i18n"

const locale = "cs" as const
const t = useTranslations(locale)

const streamingPlatforms = ["spotify", "bandcamp", "soundcloud", "youtube"] as const
---

<BaseLayout
  title={t("meta.music.title")}
  description={t("meta.music.description")}
  lang={locale}
>
  <div class="relative pt-24 pb-16 px-4 sm:px-6 lg:px-8 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-pal-9/10 rounded-full blur-3xl" />
      <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-pal-5/10 rounded-full blur-3xl" />
    </div>
    <div class="relative z-10 text-center max-w-4xl mx-auto">
      <span class="accent-line mb-4 block mx-auto" />
      <h1 class="text-4xl sm:text-6xl font-bold text-accent mb-4">{t("music.heading")}</h1>
      <p class="text-text/60 text-lg max-w-md mx-auto">{t("music.subtitle")}</p>
    </div>
  </div>

  <div class="section-divider max-w-xs mx-auto mb-16" />

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
      <div class="glass-card p-6 flex flex-col items-center md:items-start text-center md:text-left">
        <h2 class="text-2xl font-semibold text-accent mb-4">{t("music.latestSingle")}</h2>
        <div class="w-full">
          <div class="embed-responsive embed-responsive--large-track">
            <div class="embed-inner">
              <iframe
                loading="lazy"
                src="https://bandcamp.com/EmbeddedPlayer/track=389067325/size=large/bgcol=333333/linkcol=ffffff/tracklist=false/transparent=true/"
                title={t("music.singleIframeTitle")}
              ><a href="https://lishkee.bandcamp.com/track/nightmares">{t("music.singleIframeFallback")}</a></iframe>
            </div>
          </div>
        </div>
      </div>

      <div class="glass-card p-6 flex flex-col items-center md:items-start text-center md:text-left">
        <h2 class="text-2xl font-semibold text-accent mb-4">{t("music.latestAlbum")}</h2>
        <div class="w-full">
          <div class="embed-responsive embed-responsive--album">
            <div class="embed-inner">
              <iframe
                loading="lazy"
                src="https://bandcamp.com/EmbeddedPlayer/album=408392112/size=large/bgcol=333333/linkcol=ffffff/transparent=true/"
                title={t("music.albumIframeTitle")}
              ><a href="https://lishkee.bandcamp.com/album/collections-of-pink-blue-all-the-other-colors-too">{t("music.albumIframeFallback")}</a></iframe>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider max-w-xs mx-auto mb-16" />

  {/* Listen Everywhere */}
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-16 text-center">
    <span class="accent-line mb-4 block mx-auto" />
    <h2 class="text-2xl sm:text-3xl font-semibold text-accent mb-3">{t("music.listenEverywhere")}</h2>
    <p class="text-text/60 text-base mb-8 max-w-md mx-auto">{t("music.listenEverywhereDesc")}</p>

    <div class="flex flex-wrap gap-3 justify-center">
      {streamingPlatforms.map((key) => {
        const url = band.socials[key]
        return url ? (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-2.5 px-6 py-3 border border-white/10 rounded-xl text-sm font-medium text-text/80 hover:text-accent hover:border-accent/40 hover:bg-accent/5 transition-colors duration-200"
          >
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
              <path d={socialIcons[key] || ""} />
            </svg>
            {socialLabels[key] || key}
          </a>
        ) : null
      })}
    </div>
  </section>

  <div class="section-divider max-w-xs mx-auto mb-16" />

  {/* Cross-page CTA */}
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20 text-center">
    <a
      href={localePath("/shows", locale)}
      class="btn-gradient text-sm sm:text-base inline-block"
    >
      {t("music.showsCta")}
    </a>
  </section>
</BaseLayout>
