---
import { Image } from "astro:assets"
import BaseLayout from "../../layouts/BaseLayout.astro"
import { band } from "../../data/band"
import { socialLabels, socialIcons } from "../../data/socials"
import { useTranslations } from "../../i18n"

import heroBg from "../../assets/images/lishkee4-tomas-skoda.jpg"

const locale = "cs" as const
const t = useTranslations(locale)

/**
 * Renders the bio text with:
 * - Markdown-style *italic* for album/single titles
 * - Specific phrases linked
 * - Paragraph breaks preserved
 */
function renderBio(bio: string, socialsLabel: string): string {
  let html = bio
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")

  html = html.replace(/\*([^*]+)\*/g, "<em>$1</em>")

  html = html.replace(
    /<em>Layers<\/em>/g,
    '<a href="https://lishkee.bandcamp.com/album/layers-2?t=2" target="_blank" rel="noopener noreferrer" aria-label="Layers" class="text-accent hover:text-accent-hover underline underline-offset-2 transition-colors">𝓛𝓪𝔂𝓮𝓻𝓼</a>'
  )
  html = html.replace(
    /<em>Distortions<\/em>/g,
    '<a href="https://lishkee.bandcamp.com/track/distortions" target="_blank" rel="noopener noreferrer" aria-label="Distortions" class="text-accent hover:text-accent-hover underline underline-offset-2 transition-colors">𝓓𝓲𝓼𝓽𝓸𝓻𝓽𝓲𝓸𝓷𝓼</a>'
  )
  html = html.replace(
    /<em>Labyrint<\/em>/g,
    '<a href="https://kaznice.art/program/divadelni-svet-brno-labyrint/" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-hover underline underline-offset-2 transition-colors"><em>Labyrint</em></a>'
  )
  html = html.replace(
    /<em>Collections of Pink, Blue, and All the Other Colors, Too<\/em>/g,
    '<a href="https://lishkee.bandcamp.com/album/collections-of-pink-blue-all-the-other-colors-too" target="_blank" rel="noopener noreferrer" aria-label="Collections of Pink, Blue, and All the Other Colors, Too" class="text-accent hover:text-accent-hover underline underline-offset-2 transition-colors">𝓒𝓸𝓵𝓵𝓮𝓬𝓽𝓲𝓸𝓷𝓼 𝓸𝓯 𝓟𝓲𝓷𝓴, 𝓑𝓵𝓾𝓮, 𝓪𝓷𝓭 𝓐𝓵𝓵 𝓽𝓱𝓮 𝓞𝓽𝓱𝓮𝓻 𝓒𝓸𝓵𝓸𝓻𝓼, 𝓣𝓸𝓸</a>'
  )

  const linkUrl = "https://linktr.ee/lishkee"
  const linkText = "linktr.ee/lishkee"

  // Convert explicit URL occurrences in the bio to a proper anchor
  html = html.replace(/linktr\.ee\/lishkee/g, `<a href="${linkUrl}" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-hover underline underline-offset-2 transition-colors">${linkText}</a>`)

  // Replace the localized socials label with the Linktree URL (handles grammatical variants)
  const escapedSocials = socialsLabel.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")
  const socialsRegex = new RegExp(escapedSocials, "g")
  html = html.replace(
    socialsRegex,
    `<a href="${linkUrl}" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-hover underline underline-offset-2 transition-colors">${socialsLabel}</a>`
  )

  // If neither the explicit URL nor the socials label was present, append a fallback link
  if (!html.includes(linkText)) {
    html += `\n\n<a href="${linkUrl}" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-hover underline underline-offset-2 transition-colors">${linkText}</a>`
  }

  html = html
    .split("\n\n")
    .map((p) => `<p class="mb-6 leading-relaxed">${p.trim()}</p>`)
    .join("")

  return html
}

const bioHtml = renderBio(t("about.bio"), t("about.theirSocials"))
---

<BaseLayout
  title={t("meta.about.title")}
  description={t("meta.about.description")}
  lang={locale}
>
  {/* Hero banner with band photo */}
  <div class="relative w-full h-[50vh] sm:h-[65vh] overflow-hidden">
    <Image
      src={heroBg}
      alt={t("about.heroAlt")}
      widths={[640, 1024, 1440, 1920]}
      sizes="100vw"
      class="w-full h-full object-cover object-[center_20%]"
      loading="eager"
      format="webp"
      quality={80}
    />
    {/* Gradient overlays */}
    <div class="absolute inset-0 bg-gradient-to-b from-bg/40 via-transparent to-bg" />
    <div class="absolute inset-0 bg-gradient-to-t from-bg via-bg/20 to-transparent" />

    {/* Page title overlaid */}
    <div class="absolute bottom-12 left-0 right-0 z-10 text-center">
      <span class="accent-line mb-4 block mx-auto" />
      <h1 class="text-4xl sm:text-6xl font-bold text-accent drop-shadow-[0_4px_30px_rgba(0,0,0,0.5)]">
        {t("about.heading")}
      </h1>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    {/* Bio text */}
    <div class="text-text/85 text-base sm:text-lg leading-relaxed mb-16" set:html={bioHtml} />

    <div class="section-divider mb-16" />

    {/* Members section */}
    <section class="mb-16">
      <div class="text-center mb-8">
        <span class="accent-line mb-4 block mx-auto" />
        <h2 class="text-3xl sm:text-4xl font-semibold text-accent">
          {t("about.theDuo")}
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {band.members.map((member) => (
          <div class="glass-card p-6 text-center">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-accent/10 flex items-center justify-center">
              <span class="text-2xl font-bold text-accent">{member.name.charAt(0)}</span>
            </div>
            <h3 class="text-lg font-semibold text-text">{member.name}</h3>
            {member.cs_role ? (
              <p class="text-sm text-text/80 mt-2"><strong>{member.cs_role}</strong></p>
            ) : member.role ? (
              <p class="text-sm text-text/80 mt-2"><strong>{member.role}</strong></p>
            ) : null}
            {member.cs_description ? (
              <p class="text-sm text-text/70 mt-2">{member.cs_description}</p>
            ) : member.description ? (
              <p class="text-sm text-text/70 mt-2">{member.description}</p>
            ) : null}
          </div>
        ))}
      </div>
      <p class="text-center text-muted text-sm mt-6">
        {t("about.basedIn")}
      </p>
    </section>
    
    <div class="section-divider mb-12" />

    <section class="mb-16">
      <div class="glass-card p-6 text-center">
        <h4 class="text-accent font-semibold mb-2">{t("about.contactBooking")}</h4>
        <p class="text-text/80">{t("about.bookingPress")} <a href="mailto:lishkee.cz@gmail.com" class="text-accent hover:text-accent-hover underline underline-offset-2">lishkee.cz@gmail.com</a></p>
        <p class="text-text/80 mt-3">{t("about.moreLinks")} <a href="https://linktr.ee/lishkee" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-hover underline underline-offset-2">linktr.ee/lishkee</a></p>
      </div>
    </section>

    <div class="section-divider mb-16" />

    {/* Socials section */}
    <section class="mb-8">
      <div class="text-center mb-8">
        <span class="accent-line mb-4 block mx-auto" />
        <h2 class="text-3xl sm:text-4xl font-semibold text-accent">
          {t("about.followUs")}
        </h2>
      </div>

      <div class="flex flex-wrap gap-3 justify-center">
        {Object.entries(band.socials).map(([key, url]) =>
          url ? (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center gap-2.5 px-6 py-3 border border-white/10 rounded-xl text-sm font-medium text-text/80 hover:text-accent hover:border-accent/40 hover:bg-accent/5 transition-all duration-300"
            >
              <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                <path d={socialIcons[key] || ""} />
              </svg>
              {socialLabels[key] || key}
            </a>
          ) : null
        )}
      </div>
    </section>
  </div>
</BaseLayout>
