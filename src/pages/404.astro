---
import BaseLayout from "../layouts/BaseLayout.astro"
import { useTranslations, getLocaleFromUrl, localePath } from "../i18n"

const locale = getLocaleFromUrl(Astro.url.pathname)
const t = useTranslations(locale)
const basePath = (import.meta.env.BASE_URL ?? "/").replace(/\/$/, "")
---

<BaseLayout
  title={t("meta.404.title")}
  description={t("404.message")}
  lang={locale}
>
  <div class="relative pt-32 pb-20 px-4 sm:px-6 lg:px-8 overflow-hidden min-h-[60vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <div class="absolute top-1/4 left-1/3 w-[400px] h-[400px] bg-pal-9/10 rounded-full blur-3xl" />
      <div class="absolute bottom-1/4 right-1/3 w-[300px] h-[300px] bg-pal-5/10 rounded-full blur-3xl" />
    </div>

    <div class="relative z-10 text-center max-w-lg mx-auto">
      <img
        src={`${basePath}/icons/fox-svgrepo-com.svg`}
        alt=""
        class="w-24 h-24 sm:w-32 sm:h-32 mx-auto mb-8"
        aria-hidden="true"
      />
      <span class="accent-line mb-6 block mx-auto" />
      <h1 class="text-3xl sm:text-5xl font-bold text-accent mb-4">{t("404.heading")}</h1>
      <p class="text-text/70 text-base sm:text-lg mb-10">{t("404.message")}</p>
      <a
        href={localePath("/", locale)}
        class="btn-gradient text-sm sm:text-base inline-block"
      >
        {t("404.backHome")}
      </a>
    </div>
  </div>
</BaseLayout>
