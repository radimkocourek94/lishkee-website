---
import BaseLayout from "../layouts/BaseLayout.astro"
---

<BaseLayout title="Music — Lishkee">
  <div class="relative pt-24 pb-16 px-4 sm:px-6 lg:px-8 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-pal-9/10 rounded-full blur-3xl" />
      <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-pal-5/10 rounded-full blur-3xl" />
    </div>
    <div class="relative z-10 text-center max-w-4xl mx-auto">
      <span class="accent-line mb-4 block mx-auto" />
      <h1 class="text-4xl sm:text-6xl font-bold text-accent mb-4">Music</h1>
      <p class="text-text/60 text-lg max-w-md mx-auto">Albums, singles, and everything in between</p>
    </div>
  </div>

  <div class="section-divider max-w-xs mx-auto mb-16" />

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
      <div class="glass-card p-6 flex flex-col items-center md:items-start text-center md:text-left">
        <h2 class="text-2xl font-semibold text-accent mb-4">Latest single</h2>
        <div class="flex justify-center md:justify-start">
          <iframe style="border: 0; width: 350px; height: 442px;" src="https://bandcamp.com/EmbeddedPlayer/track=389067325/size=large/bgcol=333333/linkcol=ffffff/tracklist=false/transparent=true/" seamless><a href="https://lishkee.bandcamp.com/track/nightmares">Nightmares by Lishkee</a></iframe>
        </div>
      </div>

      <div class="glass-card p-6 flex flex-col items-center md:items-start text-center md:text-left">
        <h2 class="text-2xl font-semibold text-accent mb-4">Latest album</h2>
        <div class="flex justify-center md:justify-start">
          <iframe style="border: 0; width: 350px; height: 786px;" src="https://bandcamp.com/EmbeddedPlayer/album=408392112/size=large/bgcol=333333/linkcol=ffffff/transparent=true/" seamless><a href="https://lishkee.bandcamp.com/album/collections-of-pink-blue-all-the-other-colors-too">Collections of Pink, Blue, &amp; All the Other Colors, Too by Lishkee</a></iframe>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
