---
import BaseLayout from "../layouts/BaseLayout.astro"
import { band } from "../data/band"

/**
 * Renders the bio text with:
 * - Markdown-style *italic* for album/single titles
 * - Specific phrases linked (with TODO placeholders for real URLs)
 * - Paragraph breaks preserved
 */
function renderBio(bio: string): string {
  let html = bio
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")

  html = html.replace(/\*([^*]+)\*/g, "<em>$1</em>")

  html = html.replace(
    /<em>Layers<\/em>/g,
    '<a href="#" class="text-accent hover:text-accent-hover underline underline-offset-2 transition-colors"><em>Layers</em></a>'
  )
  html = html.replace(
    /<em>Distortions<\/em>/g,
    '<a href="#" class="text-accent hover:text-accent-hover underline underline-offset-2 transition-colors"><em>Distortions</em></a>'
  )
  html = html.replace(
    /<em>Labyrint<\/em>/g,
    '<a href="#" class="text-accent hover:text-accent-hover underline underline-offset-2 transition-colors"><em>Labyrint</em></a>'
  )
  html = html.replace(
    /their socials/g,
    '<a href="#" class="text-accent hover:text-accent-hover underline underline-offset-2 transition-colors">their socials</a>'
  )

  html = html
    .split("\n\n")
    .map((p) => `<p class="mb-6 leading-relaxed">${p.trim()}</p>`)
    .join("")

  return html
}

const bioHtml = renderBio(band.bio)

const socialLabels: Record<string, string> = {
  instagram: "Instagram",
  youtube: "YouTube",
  facebook: "Facebook",
  spotify: "Spotify",
  soundcloud: "SoundCloud",
  bandcamp: "Bandcamp",
  threads: "Threads",
  tiktok: "TikTok",
}

