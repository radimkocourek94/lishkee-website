---
import { tracks } from "../data/tracks"
import makeResponsiveEmbed from "../utils/embed"

// Separate featured track (has embed) from the rest
const featuredTrack = tracks.find((t) => t.embedHtml)
const otherTracks = tracks.filter((t) => t !== featuredTrack)
---

<section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
  {/* Section header */}
  <div class="text-center mb-12">
    <span class="accent-line mb-4 block mx-auto" />
    <h2 class="font-[Cormorant_Garamond] text-3xl sm:text-5xl font-semibold text-accent mb-3">
      Latest Tracks
    </h2>
    <p class="text-muted text-sm sm:text-base">Explore our music</p>
  </div>

  {/* Featured track with embed - prominent display */}
  {featuredTrack && featuredTrack.embedHtml && (
    <div class="glass-card p-6 sm:p-8 mb-8">
      <div class="flex flex-col sm:flex-row items-center gap-6">
        <div class="w-full sm:w-auto sm:max-w-[280px] shrink-0">
          <div set:html={makeResponsiveEmbed(featuredTrack.embedHtml)} />
        </div>
        <div class="flex-1 text-center sm:text-left">
          <span class="text-accent/60 text-xs font-mono uppercase tracking-widest">Latest Single</span>
          <h3 class="font-[Cormorant_Garamond] text-2xl sm:text-3xl font-semibold text-text mt-2 mb-2">
            {featuredTrack.title}
          </h3>
          {featuredTrack.duration && (
            <span class="text-muted text-sm font-mono">{featuredTrack.duration}</span>
          )}
          {featuredTrack.infoUrl && (
            <a
              href={featuredTrack.infoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block mt-4 btn-gradient text-sm"
            >
              Listen on Bandcamp
            </a>
          )}
        </div>
      </div>
    </div>
  )}

  {/* Other tracks list */}
  <div class="grid gap-4">
    {otherTracks.map((track, index) => (
      <article class="glass-card p-5 sm:p-6 group">
        <div class="flex items-start gap-4">
          {/* Track number */}
          <div class="hidden sm:flex items-center justify-center w-10 h-10 rounded-full bg-accent/10 text-accent font-[Cormorant_Garamond] text-lg font-bold shrink-0 group-hover:bg-accent/20 transition-colors">
            {String(index + 1).padStart(2, "0")}
          </div>

          <div class="flex-1 min-w-0">
            <div class="flex items-center justify-between gap-3">
              <h3 class="text-base sm:text-lg font-semibold text-text group-hover:text-accent transition-colors truncate">
                {track.title}
              </h3>
              <span class="text-muted text-sm font-mono shrink-0">{track.duration}</span>
            </div>

            {track.embedHtml ? (
              <div class="mt-4" set:html={makeResponsiveEmbed(track.embedHtml)} />
            ) : (
              <div class="mt-3 flex items-center gap-2 text-muted text-sm">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
                </svg>
                <span class="italic">Coming soon</span>
              </div>
            )}
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
