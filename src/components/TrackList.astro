---
import { tracks } from "../data/tracks"
import makeResponsiveEmbed from "../utils/embed"
---

<section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <h2 class="font-[Cormorant_Garamond] text-3xl sm:text-4xl font-semibold text-accent mb-8 text-center">Latest tracks</h2>

  <div class="grid gap-8">
    {tracks.map((track) => (
      <article class="shadow-xl rounded-md overflow-hidden bg-white/5 backdrop-blur-sm p-4">
        <h3 class="text-lg font-semibold">{track.title} <span class="text-muted text-sm">• {track.duration}</span></h3>

        {track.embedHtml ? (
          <div class="mt-4" set:html={makeResponsiveEmbed(track.embedHtml)} />
        ) : (
          <div class="mt-4 p-6 bg-white/3 rounded text-muted italic">Streaming link coming soon — add embedHtml to <code>src/data/tracks.ts</code></div>
        )}
      </article>
    ))}
  </div>
</section>
