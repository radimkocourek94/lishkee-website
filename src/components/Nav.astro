---
import { band } from "../data/band"
import { useTranslations, localePath, getAlternateLocalePath } from "../i18n"
import type { Locale } from "../i18n"

interface Props {
  lang?: Locale
  [key: string]: unknown
}

const locale = Astro.props.lang ?? "en"
const t = useTranslations(locale)

const currentPath = Astro.url.pathname
const navLinks = [
  { href: localePath("/", locale), label: t("nav.home") },
  { href: localePath("/music", locale), label: t("nav.music") },
  { href: localePath("/about", locale), label: t("nav.about") },
]

// Normalise paths for robust active-link detection (handles trailing slashes
// and optional base prefixes). We keep this simple and only strip a single
// trailing slash — that avoids changing the root "/" value.
const normalizePath = (p: string) => (p ?? "").replace(/\/$/, "") || "/"
const normalizedCurrent = normalizePath(currentPath)
const normalizedHome = normalizePath(localePath("/", locale))

const alternate = getAlternateLocalePath(currentPath)
const switchLabel = alternate.locale === "cs" ? "CS" : "EN"
---

<nav class="sticky top-0 z-50 bg-bg/80 backdrop-blur-md border-b border-white/5" id="main-nav">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logotype -->
      <a href={localePath("/", locale)} class="font-gajraj text-2xl font-semibold tracking-wide text-accent hover:text-accent-hover transition-all duration-300 hover:drop-shadow-[0_0_12px_rgba(246,193,157,0.4)]">
        {band.logotype}
      </a>

      <!-- Desktop nav links + lang switcher -->
      <div class="hidden md:flex items-center space-x-1">
        {navLinks.map((link) => {
          const normalizedLink = normalizePath(link.href)
          const isActive =
            normalizedCurrent === normalizedLink ||
            (normalizedLink !== normalizedHome && normalizedCurrent.startsWith(normalizedLink))
          return (
            <a
              href={link.href}
              class:list={[
                "relative px-4 py-2 text-sm font-medium rounded-lg transition-all duration-300",
                isActive
                  ? "text-accent bg-accent/10"
                  : "text-text/70 hover:text-text hover:bg-white/5",
              ]}
            >
              {link.label}
              {isActive && (
                <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-5 h-0.5 bg-accent rounded-full" />
              )}
            </a>
          )
        })}
        <a
          href={alternate.path}
          class="ml-2 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider border border-white/15 rounded-lg text-text/60 hover:text-accent hover:border-accent/40 transition-all duration-300"
          aria-label={alternate.locale === "cs" ? "Přepnout na češtinu" : "Switch to English"}
        >
          {switchLabel}
        </a>
      </div>

      <!-- Hamburger button (mobile) -->
      <button
        id="hamburger-btn"
        class="md:hidden relative w-10 h-10 flex items-center justify-center text-text hover:text-accent transition-colors rounded-lg hover:bg-white/5"
        aria-label={t("nav.openMenu")}
        aria-expanded="false"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div id="mobile-menu" class="md:hidden mobile-menu-enter">
    <div class="px-4 pt-2 pb-4 space-y-1 border-t border-white/5">
      {navLinks.map((link) => {
        const normalizedLink = normalizePath(link.href)
        const isActive =
          normalizedCurrent === normalizedLink ||
          (normalizedLink !== normalizedHome && normalizedCurrent.startsWith(normalizedLink))
        return (
          <a
            href={link.href}
            class:list={[
              "block py-2.5 px-3 text-sm font-medium rounded-lg transition-all duration-200",
              isActive
                ? "text-accent bg-accent/10"
                : "text-text/70 hover:text-text hover:bg-white/5",
            ]}
          >
            {link.label}
          </a>
        )
      })}
      <a
        href={alternate.path}
        class="block py-2.5 px-3 text-sm font-medium rounded-lg text-text/60 hover:text-accent hover:bg-white/5 transition-all duration-200"
        aria-label={alternate.locale === "cs" ? "Přepnout na češtinu" : "Switch to English"}
      >
        {alternate.locale === "cs" ? "🇨🇿 Česky" : "🇬🇧 English"}
      </a>
    </div>
  </div>
</nav>

<script>
  function initNav() {
    const btn = document.getElementById("hamburger-btn")
    const menu = document.getElementById("mobile-menu")
    const icon = document.getElementById("hamburger-icon") as SVGPathElement | null

    // Close mobile menu on navigation
    menu?.classList.remove("is-open")
    if (icon) {
      icon.setAttribute("d", "M4 6h16M4 12h16M4 18h16")
    }
    btn?.setAttribute("aria-expanded", "false")

    btn?.addEventListener("click", () => {
      const isOpen = menu?.classList.contains("is-open")
      menu?.classList.toggle("is-open")
      btn.setAttribute("aria-expanded", String(!isOpen))
      if (icon) {
        icon.setAttribute(
          "d",
          isOpen ? "M4 6h16M4 12h16M4 18h16" : "M6 18L18 6M6 6l12 12"
        )
      }
    })

    // Add nav background on scroll
    const nav = document.getElementById("main-nav")
    window.addEventListener("scroll", () => {
      if (window.scrollY > 50) {
        nav?.classList.add("bg-bg/95", "shadow-lg", "shadow-black/20")
        nav?.classList.remove("bg-bg/80")
      } else {
        nav?.classList.remove("bg-bg/95", "shadow-lg", "shadow-black/20")
        nav?.classList.add("bg-bg/80")
      }
    })
  }

  // Run on initial load and after each view transition navigation
  initNav()
  document.addEventListener("astro:after-swap", initNav)
</script>
