---
/**
 * MailingListForm — modern mailing list signup CTA.
 * Uses Netlify Forms attribute for post-deploy compatibility.
 */
---

<section class="relative py-24 px-4 sm:px-6 lg:px-8 overflow-hidden">
  {/* Background decoration */}
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-accent/5 rounded-full blur-3xl" />
  </div>

  <div class="relative z-10 max-w-lg mx-auto text-center">
    {/* Decorative line */}
    <span class="accent-line mb-6 block mx-auto" />

    <h2 class="font-[Cormorant_Garamond] text-3xl sm:text-5xl font-semibold text-accent mb-4">
      Stay in the Loop
    </h2>
    <p class="text-text/70 mb-8 text-base sm:text-lg">
      Be the first to hear about new releases, shows, and behind-the-scenes updates.
    </p>

    <form
      name="mailing-list"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="space-y-4"
    >
      {/* Honeypot field for spam prevention */}
      <p class="hidden">
        <label>
          Don't fill this out: <input name="bot-field" />
        </label>
      </p>

      <input type="hidden" name="form-name" value="mailing-list" />

      <div class="flex flex-col sm:flex-row gap-3">
        <input
          type="email"
          name="email"
          required
          placeholder="your@email.com"
          class="flex-1 px-5 py-3.5 bg-white/5 border border-white/10 rounded-xl text-text placeholder-muted focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all duration-300 backdrop-blur-sm"
        />

        <button
          type="submit"
          class="btn-gradient cursor-pointer whitespace-nowrap"
        >
          Sign Up
        </button>
      </div>

      <p class="text-muted text-xs">
        No spam, ever. Unsubscribe anytime.
      </p>
    </form>
  </div>
</section>
