---
import { band } from "../data/band"
import { socialLabels, socialIcons } from "../data/socials"
import { useTranslations, localePath } from "../i18n"
import type { Locale } from "../i18n"

interface Props {
  lang?: Locale
  [key: string]: unknown
}

const locale = Astro.props.lang ?? "en"
const t = useTranslations(locale)
const year = new Date().getFullYear()
---

<footer class="relative border-t border-white/5 mt-0" transition:name="footer">
  {/* Gradient top edge */}
  <div class="section-divider" />

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- layout: left / center / right on sm+; centered on mobile -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 sm:gap-12 items-start">
      {/* Brand */}
      <div class="sm:justify-self-start text-center sm:text-left">
        <a href={localePath("/", locale)} class="font-gajraj text-2xl font-semibold text-accent hover:text-accent-hover transition-colors">
          {band.logotype}
        </a>
        <p class="text-muted text-sm mt-2">{band.location}</p>
      </div>

      {/* Quick links */}
      <div class="sm:justify-self-center text-center">
        <h3 class="text-sm font-semibold text-text uppercase tracking-wider mb-3">{t("footer.navigate")}</h3>
          <div class="flex flex-wrap items-center justify-center gap-4">
            <a href={localePath("/", locale)} class="text-sm text-muted hover:text-accent transition-colors">{t("nav.home")}</a>
            <a href={localePath("/music", locale)} class="text-sm text-muted hover:text-accent transition-colors">{t("nav.music")}</a>
            <a href={localePath("/shows", locale)} class="text-sm text-muted hover:text-accent transition-colors">{t("nav.shows")}</a>
            <a href={localePath("/about", locale)} class="text-sm text-muted hover:text-accent transition-colors">{t("nav.about")}</a>
          </div>
      </div>

      {/* Social links */}
      <div class="sm:justify-self-end text-center sm:text-right">
        <h3 class="text-sm font-semibold text-text uppercase tracking-wider mb-3">{t("footer.connect")}</h3>
        <div class="flex flex-wrap items-center justify-center sm:justify-end gap-3">
          {Object.entries(band.socials).map(([key, url]) =>
            url ? (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-white/5 text-muted hover:text-accent hover:bg-accent/10 transition-colors"
                aria-label={socialLabels[key] || key}
              >
                <span class="sr-only">{socialLabels[key] || key}</span>
                <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                  <path d={socialIcons[key] || ""} />
                </svg>
              </a>
            ) : null
          )}
        </div>
      </div>
    </div>

    {/* Bottom bar */}
    <div class="mt-10 pt-6 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-muted">
      <p>&copy; {year} {band.name}. {t("footer.allRightsReserved")}</p>
      <p>{t("footer.photosBy")} {band.photoCredit}</p>
    </div>
  </div>
</footer>
